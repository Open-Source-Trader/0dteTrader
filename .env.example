# ---- API ----
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://odtetrader:odtetrader@localhost:5432/odtetrader

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL=900          # seconds (15 min)
JWT_REFRESH_TTL=1209600     # seconds (14 days)

# Credential encryption: 32-byte key, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CRED_ENCRYPTION_KEY=change-me-base64-32-byte-key

# Broker gateway: "mock" or "webull"
BROKER_GATEWAY=mock

# Webull OpenAPI (backend-level settings; per-user creds are stored encrypted in DB)
# Sandbox/paper: https://api.sandbox.webull.com (default) — live: https://api.webull.com
WEBULL_API_BASE_URL=https://api.sandbox.webull.com
# Optional separate market-data host (default: derived from WEBULL_API_BASE_URL,
# i.e. api.sandbox.webull.com → data-api.sandbox.webull.com)
WEBULL_MARKET_DATA_BASE_URL=

# Webull developer app credentials — used ONLY by the smoke script
# (npm run smoke:webull). The API itself does NOT read these: each user's
# app key/secret/account ID are entered once in the app (Profile → Webull API)
# and stored AES-256-GCM encrypted in the database.
WEBULL_APP_KEY=
WEBULL_APP_SECRET=

# Informational only — NOT read by any code. The OpenAPI authenticates with
# app key + secret + account ID; the 6-digit trading PIN is never used by the
# API and should not be stored here. Keep or delete as you like.
WEBULL_APPLICATION_ID=
WEBULL_APPLICATION_NAME=
WEBULL_ACCOUNT_PHONE_NUMBER=