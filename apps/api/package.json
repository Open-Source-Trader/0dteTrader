{
  "name": "@0dtetrader/api",
  "version": "0.1.0",
  "private": true,
  "description": "0dteTrader backend API (NestJS + Prisma + Webull OpenAPI proxy)",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "dev": "npm run build && node --watch dist/main.js",
    "start": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "jest --runInBand",
    "smoke:webull": "npm run build && node dist/scripts/webull-smoke.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@0dtetrader/shared-types": "*",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/platform-ws": "^11.1.28",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.28",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.45.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "helmet": "^8.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.28",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.1",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "dotenv": "^17.2.4",
    "eslint": "^10.7.0",
    "jest": "^30.4.2",
    "prisma": "^7.8.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "~6.0.3"
  }
}
