// 0dteTrader data model — see docs/ARCHITECTURE.md §5.
//
// Notes:
// - `User.email` is a plain String with a unique index; case-insensitivity is
//   enforced at the application layer (emails are lowercased before any
//   read/write) instead of the citext extension so no extension is required.
// - `WebullCredential` stores AES-256-GCM encrypted fields. Each enc_* column
//   holds a self-contained blob: iv (12 bytes) || authTag (16 bytes) ||
//   ciphertext. A single shared iv/auth_tag column pair cannot safely hold
//   per-field GCM parameters without reusing nonces, so each field carries its
//   own parameters (random 12-byte IV per field per write — IVs are never
//   reused).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String             @id @default(uuid()) @db.Uuid
  email           String             @unique
  passwordHash    String
  tradingDisabled Boolean            @default(false)
  tradingMode     String             @default("live")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  credentials     WebullCredential[]
  refreshTokens   RefreshToken[]
  orderAudits     OrderAudit[]
  webullApiTokens WebullApiToken[]
  tradeOrders     TradeOrder[]

  @@map("users")
}

model WebullCredential {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // "live" | "practice" — one credential set per environment per user.
  environment  String   @default("live")
  encAppKey    Bytes
  encAppSecret Bytes
  // Null until discovered via GET /openapi/account/list (the official flow:
  // the user supplies only app key/secret; the account id is fetched).
  encAccountId Bytes?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, environment])
  @@map("webull_credentials")
}

// Persisted Webull OpenAPI access tokens (encrypted) so restarts reuse the
// existing token instead of re-creating one — every create on production
// triggers SMS re-verification in the user's Webull app. One row per
// (user, environment), mirroring webull_credentials.
model WebullApiToken {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // "live" | "practice"
  environment String   @default("live")
  encToken    Bytes
  expiresAt   DateTime
  // NORMAL | PENDING (awaiting in-app 2FA verification)
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, environment])
  @@map("webull_api_tokens")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// One row per broker order, kept current as order-update events arrive
// (fills land asynchronously). Feeds the trade-history endpoint.
model TradeOrder {
  id             String   @id // broker orderId
  userId         String   @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contractSymbol String
  assetClass     String
  // "live" | "practice" — tradingMode in effect when the order was recorded.
  environment    String   @default("live")
  side           String
  quantity       Float
  // Broker-reported executed quantity (partial fills); null when the broker
  // gives only the order quantity.
  filledQuantity Float?
  orderType      String
  limitPrice     Float?
  filledPrice    Float?
  status         String
  placedAt       DateTime
  updatedAt      DateTime @updatedAt

  @@index([userId, placedAt])
  @@map("trade_orders")
}

model OrderAudit {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  idempotencyKey String?
  request        Json
  response       Json?
  status         String
  createdAt      DateTime @default(now())

  @@unique([userId, idempotencyKey])
  @@index([userId])
  @@map("order_audits")
}

model OptionsAnalyticsSnapshotRecord {
  id                 String   @id @default(uuid()) @db.Uuid
  symbol             String
  expiration         String
  observedAt         DateTime
  settlementAt       DateTime
  bucket             DateTime
  // "core" | "viewed"; enforced by a database check constraint.
  captureReason      String
  // 1 | 5; enforced by a database check constraint.
  resolutionMinutes  Int
  calculationVersion String
  input              Json
  output             Json
  quality            Json
  createdAt          DateTime @default(now())

  @@unique([symbol, expiration, bucket, calculationVersion, resolutionMinutes], map: "options_analytics_snapshot_identity_key")
  @@index([resolutionMinutes, bucket])
  @@map("options_analytics_snapshots")
}

model ScheduledJobLease {
  name      String   @id
  ownerId   String
  expiresAt DateTime
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
  @@map("scheduled_job_leases")
}
