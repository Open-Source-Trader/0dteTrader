{
  "name": "0dtetrader",
  "private": true,
  "version": "0.1.0",
  "description": "0dteTrader — rapid options trading app for Webull OpenAPI",
  "workspaces": [
    "apps/api",
    "apps/desktop",
    "packages/shared-types"
  ],
  "scripts": {
    "prepare": "husky",
    "setup": "node scripts/setup.js",
    "dev": "npm run build --workspace packages/shared-types && npm run dev --workspace apps/api",
    "dev:api": "npm run dev --workspace apps/api",
    "dev:desktop": "npm run dev --workspace apps/desktop",
    "dev:all": "npm run build --workspace packages/shared-types && concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:desktop\"",
    "build": "npm run build --workspace packages/shared-types && npm run build --workspace apps/api && npm run build --workspace apps/desktop",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "npm run db:migrate --workspace apps/api",
    "smoke:webull": "npm run smoke:webull --workspace apps/api",
    "smoke:snaptrade": "npm run smoke:snaptrade --workspace apps/api",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=22.12"
  },
  "dependencies": {
    "playwright-core": "^1.61.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^10.0.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.5",
    "typescript-eslint": "^8.64.0"
  }
}
